# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# Groq (free tier - get at console.groq.com)
GROQ_API_KEY=YOUR_GROQ_KEY

# OpenAI (optional - for baseline comparison only)
OPENAI_API_KEY=

# Google Cloud (optional - for ASR evaluation only)
GOOGLE_APPLICATION_CREDENTIALS=

# ASR Configuration
ASR_PRIMARY_PROVIDER=whisper          # whisper | google | indic
ASR_WHISPER_MODEL=base                # tiny | base | small | medium | large-v3
ASR_WHISPER_DEVICE=cpu                # cpu | cuda
ASR_WHISPER_COMPUTE_TYPE=int8         # int8 | float16 | float32

# LLM Configuration
LLM_PROVIDER=groq                     # groq | openai | gemini
LLM_MODEL=llama-3.1-70b-versatile    # groq model

# App
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173
